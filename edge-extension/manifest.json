{
  "manifest_version": 3,
  "name": "快捷搜索后台加载器",
  "version": "3.0.0",
  "description": "在 Edge 后台加载搜索页，提取非广告结果并发送给快捷搜索悬浮窗。",
  "minimum_chrome_version": "116",
  "permissions": ["alarms", "scripting"],
  "host_permissions": [
    "https://www.google.com/*",
    "https://www.bing.com/*",
    "https://www.baidu.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "快捷搜索后台加载器"
  }
}
